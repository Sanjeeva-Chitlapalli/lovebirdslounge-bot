# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lovebirds-lounge




# LINE Group / Target IDs (optional, for push messages)
LINE_GROUP_ID=your_line_group_id_here

# Cron Schedules (cron syntax)
REMINDER_CRON_SCHEDULE=0 8 * * *
SUMMARY_CRON_SCHEDULE=0 21 * * 0

# App Base URL (for portal links)
BASE_URL=https://your-domain.com
